rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: carts
    // Document ID: {userId}
    // Fields:
    //   - items: list (required) - Array of cart items
    //   - updatedAt: timestamp (required) - Last updated time
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - phone: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Subcollection: addresses (under users/{userId})
    // Document ID: {addressId}
    // Fields:
    //   - fullName: string (required)
    //   - phone: string (required)
    //   - addressLine1: string (required)
    //   - addressLine2: string (optional)
    //   - city: string (required)
    //   - state: string (required)
    //   - pincode: string (required)
    //   - landmark: string (optional)
    //   - latitude: number (optional)
    //   - longitude: number (optional)
    //   - formattedAddress: string (optional)
    //   - placeId: string (optional)
    //   - isDefault: boolean (required)
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - shippingAddress: map (required)
    //   - paymentMethod: string (required)
    //   - paymentStatus: string (required)
    //   - orderStatus: string (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sumanthbolla97@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidCart(data) {
      return hasRequiredFields(['items', 'updatedAt']) &&
             hasOnlyAllowedFields(['items', 'updatedAt']) &&
             data.items is list && data.items.size() <= 100 &&
             data.updatedAt is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['name', 'email', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'email', 'phone', 'createdAt', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             data.createdAt is timestamp;
    }

    function isValidAddress(data) {
      return hasRequiredFields(['fullName', 'phone', 'addressLine1', 'city', 'state', 'pincode', 'isDefault']) &&
             hasOnlyAllowedFields(['fullName', 'phone', 'addressLine1', 'addressLine2', 'city', 'state', 'pincode', 'landmark', 'latitude', 'longitude', 'formattedAddress', 'placeId', 'isDefault']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.addressLine1 is string && data.addressLine1.size() > 0 && data.addressLine1.size() < 200 &&
             (!('addressLine2' in data) || (data.addressLine2 is string && data.addressLine2.size() < 200)) &&
             data.city is string && data.city.size() > 0 && data.city.size() < 100 &&
             data.state is string && data.state.size() > 0 && data.state.size() < 100 &&
             data.pincode is string && data.pincode.size() > 0 && data.pincode.size() < 20 &&
             (!('landmark' in data) || (data.landmark is string && data.landmark.size() < 100)) &&
             (!('latitude' in data) || data.latitude is number) &&
             (!('longitude' in data) || data.longitude is number) &&
             (!('formattedAddress' in data) || (data.formattedAddress is string && data.formattedAddress.size() < 500)) &&
             (!('placeId' in data) || (data.placeId is string && data.placeId.size() < 200)) &&
             data.isDefault is bool;
    }

    function isValidOrder(data) {
      return hasRequiredFields(['userId', 'items', 'totalAmount', 'shippingAddress', 'paymentMethod', 'paymentStatus', 'orderStatus', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'items', 'totalAmount', 'shippingAddress', 'paymentMethod', 'paymentStatus', 'orderStatus', 'createdAt']) &&
             data.userId is string &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.shippingAddress is map &&
             data.shippingAddress.keys().hasAll(['fullName', 'phone', 'addressLine1', 'city', 'state', 'pincode']) &&
             data.shippingAddress.fullName is string && data.shippingAddress.fullName.size() > 0 &&
             data.shippingAddress.phone is string && data.shippingAddress.phone.size() > 0 &&
             data.shippingAddress.addressLine1 is string && data.shippingAddress.addressLine1.size() > 0 &&
             data.shippingAddress.city is string && data.shippingAddress.city.size() > 0 &&
             data.shippingAddress.state is string && data.shippingAddress.state.size() > 0 &&
             data.shippingAddress.pincode is string && data.shippingAddress.pincode.size() > 0 &&
             data.paymentMethod in ['COD'] &&
             data.paymentStatus in ['Pending', 'Paid', 'Failed'] &&
             data.orderStatus in ['Confirmed', 'Preparing', 'Packed', 'Out for Delivery', 'Delivered', 'Cancelled'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'description', 'price', 'images', 'ingredients', 'stock', 'SKU', 'category', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'description', 'price', 'offerPrice', 'images', 'ingredients', 'stock', 'SKU', 'category', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.price is number && data.price >= 0 &&
             (!('offerPrice' in data) || (data.offerPrice is number && data.offerPrice >= 0 && data.offerPrice < data.price)) &&
             data.images is list && data.images.size() <= 10 &&
             data.ingredients is list && data.ingredients.size() <= 100 &&
             data.stock is number && data.stock >= 0 &&
             data.SKU is string && data.SKU.size() > 0 && data.SKU.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.createdAt is timestamp;
    }

    function isValidInventoryLog(data) {
      return hasRequiredFields(['productId', 'productName', 'userId', 'userEmail', 'previousStock', 'newStock', 'quantityChanged', 'changeType', 'createdAt']) &&
             hasOnlyAllowedFields(['productId', 'productName', 'userId', 'userEmail', 'previousStock', 'newStock', 'quantityChanged', 'changeType', 'reason', 'createdAt']) &&
             data.productId is string &&
             data.productName is string &&
             data.userId is string &&
             data.userEmail is string &&
             data.previousStock is number && data.previousStock >= 0 &&
             data.newStock is number && data.newStock >= 0 &&
             data.quantityChanged is number &&
             data.quantityChanged == (data.newStock - data.previousStock) &&
             data.changeType in ['restock', 'adjustment', 'sale'] &&
             (!('reason' in data) || data.reason is string) &&
             data.createdAt is timestamp;
    }

    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidCart(request.resource.data);
      allow update: if isOwner(userId) && isValidCart(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /inventory_logs/{logId} {
      allow read: if isAdmin();
      allow create: if (isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.changeType == 'sale')) && isValidInventoryLog(request.resource.data);
      allow update, delete: if false; // Logs are immutable
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if (isAdmin() && isValidProduct(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt) ||
                       (isAuthenticated() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
                        request.resource.data.stock >= 0 &&
                        request.resource.data.stock < resource.data.stock);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId) && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Users cannot delete orders
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isOwner(userId);
      
      match /addresses/{addressId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAddress(request.resource.data);
        allow update: if isOwner(userId) && isValidAddress(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
